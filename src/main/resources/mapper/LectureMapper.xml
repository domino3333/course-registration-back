<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.course.mapper.LectureMapper">


    <select id="getLectureList">
        select * from Lecture
    </select>

    <update id="increaseCurrentEnrollment">
        update lecture set currentEnrollment = currentEnrollment + 1 where lecture_no = #{lectureNo}
    </update>

</mapper>