<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.course.mapper.MemberMapper">


    <select id="findMemberByEmail" resultType="Member">
        select * from member where email = #{email}
    </select>

    <insert id="signUp">
        insert into member(member_no,name,id,gender,password,email,code)
        values(seq_member.nextval,#{name},#{id},#{gender},#{password},#{email},#{code})
    </insert>
</mapper>